PORT=3000
HOST=0.0.0.0

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_COOKIE_SECRET=replace-with-a-long-random-secret

PUBLIC_BASE_URL=https://your-project.vercel.app

# Local development fallback only
APP_STORAGE_ROOT=.

# Free production deployment on Vercel + Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=audio-recordings

# Keep this at 4 MB on Vercel Hobby because request bodies above 4.5 MB are rejected
MAX_AUDIO_FILE_SIZE_MB=4
